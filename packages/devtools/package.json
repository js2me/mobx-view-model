{
  "name": "mobx-view-model-devtools",
  "version": "0.0.63",
  "description": "DevTools for mobx-view-model — inspect and debug ViewModel instances in real time",
  "keywords": [
    "mobx",
    "view-model",
    "devtools",
    "debug"
  ],
  "author": "js2me",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "clean": "rimraf dist",
    "check": "tsc --noEmit",
    "build": "cross-env NODE_ENV=development tsx scripts/build",
    "build:prod": "tsc --noEmit && cross-env NODE_ENV=production tsx scripts/build",
    "build:dev-global-only": "cross-env NODE_ENV=development GLOBAL_ONLY=true tsx scripts/build",
    "build:watch": "nodemon --watch src --delay 600ms --ext ts,tsx,css --exec \"pnpm build\"",
    "build:watch-global-only": "nodemon --watch src --delay 600ms --ext ts,tsx,css --exec \"pnpm build:dev-global-only\"",
    "serve": "pnpm exec http-server dist -p 15000",
    "build:watch-server": "nodemon --watch src --delay 600ms --ext ts,tsx,css --exec \"pnpm build && pnpm serve\"",
    "build:watch-server-global-only": "nodemon --watch src --delay 600ms --ext ts,tsx,css --exec \"pnpm build:dev-global-only && pnpm serve\""
  },
  "dependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "mobx-swiss-knife": "^1.15.0",
    "mobx-view-model": "workspace:*",
    "mobx-web-api": "^1.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simplebar": "^6.3.3",
    "virtua": "^0.49.1",
    "yummies": "^7.19.4"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "cross-env": "^10.1.0",
    "http-server": "^14.1.1",
    "lodash-es": "^4.17.21",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "postcss-selector-parser": "^7.1.1",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "terser": "^5.44.0",
    "tsx": "^4.20.6",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
