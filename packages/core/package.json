{
  "name": "mobx-view-model",
  "version": "10.0.0",
  "scripts": {
    "clean": "rimraf dist",
    "ts:check": "tsc --noEmit --project tsconfig.check.json",
    "ts-test-types:check": "tsc --noEmit --project tsconfig.test.json",
    "check": "pnpm run ts:check && pnpm ts-test-types:check",
    "prebuild": "pnpm run clean",
    "build:watch": "pnpm build && nodemon --watch src --ext ts,tsx --exec \"pnpm build\"",
    "build": "vite build",
    "pub": "pnpm build && sborshik publish --useDistDir",
    "pub:patch": "PUBLISH_VERSION=patch pnpm pub",
    "pub:minor": "PUBLISH_VERSION=minor pnpm pub",
    "pub:major": "PUBLISH_VERSION=major pnpm pub",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "keywords": [
    "mobx",
    "view-model",
    "view",
    "model",
    "vm",
    "mvvm",
    "mvc",
    "mvp",
    "ViewModel",
    "ModelViewModel"
  ],
  "author": "js2me",
  "license": "MIT",
  "description": "MobX view models core (framework-agnostic)",
  "bugs": {
    "url": "https://github.com/js2me/mobx-view-model/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "homepage": "https://github.com/js2me/mobx-view-model",
  "repository": {
    "type": "git",
    "url": "git://github.com/js2me/mobx-view-model"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "dependencies": {
    "mobx-view-model-react": "workspace:*",
    "yummies": "^7.10.0"
  },
  "peerDependencies": {
    "mobx": "^6.12.4",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-istanbul": "^4.0.18",
    "js2me-biome-config": "^1.1.0",
    "jsdom": "^26.1.0",
    "mobx-view-model-react": "workspace:*",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "sborshik": "^3.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
