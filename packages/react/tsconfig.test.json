{
  "compilerOptions": {
    "types": ["vitest", "node"],
    "target": "ESNext",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "typeRoots": ["./node_modules/@types/", "./types", "./node_modules"],
    "noEmit": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "mobx-view-model": ["../core/src/index.ts"],
      "mobx-view-model-react": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.fixture.ts"]
}
