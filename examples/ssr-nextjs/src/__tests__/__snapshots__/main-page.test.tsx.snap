exports[`Main page > should match snapshot 1`] = `"<main class="mx-auto max-w-[40rem] px-5 pb-16 pt-8"><h1 class="mb-4 text-2xl font-semibold">SSR + mobx-view-model + hydration</h1><p class="text-sm text-demo-muted">View page source: the card HTML comes from the same markup as after attach/mount; the button is disabled until the ViewModel is live. After hydration, MobX on the VM handles clicks.</p><div class="flex flex-col gap-4"><h1 class="text-2xl font-semibold">Demo page</h1><h1 class="text-2xl font-semibold">This value received from root store - "Test App"</h1><article class="mt-6 rounded-xl border border-demo-border bg-demo-card px-6 py-5"><h2 class="mb-3 text-lg font-semibold">Test headline</h2><p class="text-sm text-demo-muted">Server timestamp: 2024-01-01T00:00:00.000Z</p><p>Client clicks (MobX on the ViewModel): <strong>0</strong></p><button type="button" class="mt-4 cursor-pointer rounded-full border-0 bg-demo-accent px-4 py-2 font-semibold text-white hover:brightness-110 disabled:cursor-not-allowed disabled:bg-neutral-600 disabled:opacity-90">+1 on ViewModel</button></article><section class="mt-6 rounded-2xl border border-demo-border bg-demo-card/80 px-6 py-5"><p class="text-sm font-semibold">VMComponent with static id</p><p class="mt-1 text-sm text-demo-muted">This VMComponent renders another VMComponent with a dynamic id inside.</p><code class="mt-3 inline-flex rounded bg-demo-border/40 px-2 py-1 text-xs text-demo-muted">demo-nested-static-vm</code><div class="mt-4"><div class="rounded-xl border border-dashed border-demo-accent/40 bg-demo-card/70 p-4"><p class="text-sm font-semibold">VMComponent with dynamic id</p><p class="mt-1 text-sm text-demo-muted">This nested VMComponent is created without a fixed id.</p><code class="mt-3 inline-flex rounded bg-demo-border/40 px-2 py-1 text-xs text-demo-muted">_r_2_:NestedDemoVM</code></div></div></section></div></main>"`;
