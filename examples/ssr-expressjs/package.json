{
  "name": "mobx-view-model-example-ssr-expressjs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:styles && pnpm build:client && tsx watch --clear-screen=false src/server.tsx",
    "build:styles": "tailwindcss -i src/app/styles.css -o dist/styles.css",
    "build:client": "esbuild src/client.tsx --bundle --format=esm --platform=browser --outfile=dist/client.js",
    "build": "pnpm build:styles && pnpm build:client && tsc --noEmit",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true src",
    "check": "pnpm run lint:check && tsc --noEmit",
    "start": "NODE_ENV=production pnpm build:styles && pnpm build:client && tsx src/server.tsx",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "express": "^4.21.2",
    "lucide-react": "^1.8.0",
    "mobx": "^6.13.7",
    "mobx-location-history": "9.3.1",
    "mobx-react-lite": "^4.1.1",
    "mobx-view-model": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yummies": "^7.17.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "esbuild": "^0.25.10",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
