{
  "name": "mobx-view-model-example-csr-react18",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "esbuild src/main.tsx --bundle --alias:react=./node_modules/react --alias:react-dom=./node_modules/react-dom --format=esm --platform=browser --outfile=public/app.js --servedir=public --serve=3012",
    "build": "esbuild src/main.tsx --bundle --alias:react=./node_modules/react --alias:react-dom=./node_modules/react-dom --format=esm --platform=browser --outfile=public/app.js",
    "check": "tsc --noEmit",
    "start": "pnpm build && esbuild src/main.tsx --bundle --alias:react=./node_modules/react --alias:react-dom=./node_modules/react-dom --format=esm --platform=browser --outfile=public/app.js --servedir=public --serve=3012"
  },
  "dependencies": {
    "mobx": "^6.13.7",
    "mobx-react-lite": "^4.1.1",
    "mobx-view-model": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3"
  }
}
