{
  "name": "",
  "private": true,
  "scripts": {
    "prepare": "pnpm dev:install-hooks",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true packages",
    "check": "pnpm run lint:check && pnpm -r run check",
    "prebuild": "pnpm run clean",
    "build": "pnpm --filter mobx-view-model-react run build && pnpm --filter mobx-view-model run build && pnpm --filter mobx-view-model-devtools run build && pnpm --filter mobx-view-model-vite-plugin run build",
    "build:watch": "pnpm -r --filter './packages/*' run build:watch",
    "test": "pnpm -r --filter './packages/*' run test",
    "test:examples": "pnpm -r --filter './examples/*' run test",
    "test:watch": "pnpm -r --filter './packages/*' run test:watch",
    "test:coverage": "pnpm -r --filter './packages/*' run test:coverage",
    "test:type-regression": "node ./scripts/test-type-regression.mjs",
    "docs": "pnpm build && cd docs && pnpm dev",
    "docs:install": "pnpm install",
    "docs:build": "cd docs && pnpm install && pnpm build",
    "docs:serve": "cd docs && pnpm preview",
    "examples:build": "pnpm -r --filter './examples/*' run build",
    "example:ssr:install": "pnpm --dir examples/ssr-nextjs install",
    "example:ssr:build:example": "pnpm example:ssr:install && pnpm --dir examples/ssr-nextjs build",
    "example:ssr": "pnpm build && pnpm example:ssr:install && pnpm --dir examples/ssr-nextjs dev",
    "example:ssr:build": "pnpm build && pnpm example:ssr:build:example",
    "dev": "pnpm test:watch",
    "dev:install-hooks": "if [ -z \"$CI\" ]; then lefthook install; fi",
    "changeset:version": "changeset version && pnpm install --lockfile-only --no-frozen-lockfile"
  },
  "author": "js2me",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "commitfmt": "^1.0.4",
    "js2me-biome-config": "^1.1.0",
    "lefthook": "^1.13.6",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "sborshik": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "packageManager": "pnpm@9.5.0+sha512.140036830124618d624a2187b50d04289d5a087f326c9edfc0ccd733d76c4f52c3a313d4fc148794a2a9d81553016004e6742e8cf850670268a7387fc220c903"
}
